<%- include('../partials/header', { title: 'Profile' }) %>

  <h2><i class="fas fa-user-circle"></i> Profile</h2>

  <div class="card p-3">
    <p><strong>ID:</strong>
      <%= user.id %>
    </p>
    <p><strong>Name:</strong>
      <%= user.name %>
    </p>
    <p><strong>Email:</strong>
      <%= user.email %>
    </p>
    <div class="mt-2">
      <a href="/user/settings" class="btn btn-primary btn-sm">
        <i class="fas fa-cog"></i> Manage Settings
      </a>
      <a href="/user/dashboard" class="btn btn-secondary btn-sm">
        <i class="fas fa-arrow-left"></i> Dashboard
      </a>
    </div>
  </div>

  <%- include('../partials/footer') %>
