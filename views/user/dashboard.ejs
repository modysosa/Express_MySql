<%- include('../partials/header', { title: 'User Dashboard' }) %>

    <div class="container mt-5">
        <div class="row mb-4">
            <div class="col-md-8">
                <h1><i class="fas fa-tachometer-alt"></i> User Dashboard</h1>
            </div>
            <div class="col-md-4 text-end">
                <a href="/profile" class="btn btn-primary">
                    <i class="fas fa-user-circle"></i> My Profile
                </a>
                <a href="/logout" class="btn btn-danger">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-user-circle"></i> Welcome</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Hello, <%= user.name %>!</strong></p>
                        <p>Email: <%= user.email %>
                        </p>
                        <p>Member since: <%= new Date(user.created_at).toLocaleDateString() %>
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-info-circle"></i> Quick Links</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled">
                            <li><a href="/profile" class="btn btn-outline-primary btn-sm w-100 mb-2"><i
                                        class="fas fa-edit"></i> Edit Profile</a></li>
                            <li><a href="/users" class="btn btn-outline-info btn-sm w-100"><i class="fas fa-users"></i>
                                    View All Users</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>