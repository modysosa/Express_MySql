<%- include('../partials/header', { title: 'Users' }) %>

  <h2><i class="fas fa-users"></i> All Users</h2>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <form class="d-flex gap-2" method="GET" action="/users">
      <input
        type="text"
        name="q"
        class="form-control"
        placeholder="Search by name or email"
        value="<%= query || '' %>"
      >
      <button type="submit" class="btn btn-primary">
        <i class="fas fa-search"></i> Search
      </button>
      <% if (query) { %>
        <a href="/users" class="btn btn-outline-secondary">Clear</a>
      <% } %>
    </form>
    <span class="badge bg-dark">
      Showing <%= users.length %> of <%= typeof totalUsers === 'number' ? totalUsers : users.length %>
    </span>
  </div>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(user=> { %>
        <tr>
          <td>
            <%= user.id %>
          </td>
          <td>
            <%= user.name %>
          </td>
          <td>
            <%= user.email %>
          </td>
        </tr>
        <% }) %>
    </tbody>
  </table>

  <%- include('../partials/footer') %>
